# Railway Environment Variables
# Copy file ini ke .env dan sesuaikan dengan credentials dari Railway

# MySQL Database (dari Railway)
MYSQLHOST=your-mysql-host.railway.app
MYSQLUSER=root
MYSQLPASSWORD=your-password
MYSQLDATABASE=surat_desa
MYSQLPORT=3306

# Application URL (optional - Railway auto-set)
APP_URL=https://your-app.up.railway.app

# Port (Railway auto-set, tapi bisa di-override)
PORT=3000
